# B20 Mainnet Bot - Base Mainnet ONLY
# Copy to .env and fill values. Never commit real keys.

RPC_URL=https://mainnet.base.org
# Recommended: paid WS endpoint for reliable event streaming (faster monitoring, lower rate limits)
# RPC_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# Use WS for production sniping to reduce 429 errors and get lower latency.

PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
WALLET_ADDRESS=0xYourAddressHere

# Optional: route some submissions via Flashbots Protect or other private RPC
# Note: Flashbots Protect primarily targets Ethereum; test compatibility for Base.
FLASHBOTS_RPC=https://rpc.flashbots.net

# Safety
DRY_RUN_DEFAULT=true

# Telegram notifications (optional but recommended)
TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TG_USER_ID=123456789   # your Telegram user ID (get from @userinfobot)

# Live trading risk controls (use small values when starting)
MAX_TRADE_ETH=0.1
MAX_DAILY_LOSS_ETH=0.5
MIN_LIQUIDITY_ETH=5.0
SLIPPAGE_BPS=2000          # 20% for launches (reduce later)
KILL_SWITCH_FILE=/home/ubuntu/b20-bot/KILL_SWITCH

# RPC failover (comma separated) - add as many as you want for reliability during launches
# Public Base Mainnet RPCs (mix HTTP and WS where possible). Use paid ones for production.
BACKUP_RPCS=https://mainnet.base.org,https://base-mainnet.public.blastapi.io,https://base.meowrpc.com,https://base-pokt.nodies.app,https://rpc.ankr.com/base,https://base.drpc.org,https://1rpc.io/base,https://base.blockpi.network/v1/rpc/public,https://base.api.onfinality.io/public,https://gateway.tenderly.co/public/base,https://base.llamarpc.com,https://base.rpc.subquery.network/public,https://base-rpc.publicnode.com,wss://base-mainnet.public.blastapi.io,wss://base.meowrpc.com
