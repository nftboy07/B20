# B20 Mainnet Bot - Base Mainnet ONLY
# Copy to .env and fill values. Never commit real keys.

RPC_URL=https://mainnet.base.org
# Recommended: paid WS endpoint for reliable event streaming
# RPC_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY

PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
WALLET_ADDRESS=0xYourAddressHere

# Optional: route some submissions via Flashbots Protect or other private RPC
# Note: Flashbots Protect primarily targets Ethereum; test compatibility for Base.
FLASHBOTS_RPC=https://rpc.flashbots.net

# Safety
DRY_RUN_DEFAULT=true

# Telegram notifications (optional but recommended)
TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TG_USER_ID=123456789   # your Telegram user ID (get from @userinfobot)
